# ── Neo4j ─────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── LLM Providers (set the ones you use) ─────────
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
HF_API_TOKEN=
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT_SECONDS=120

# ── Embeddings ────────────────────────────────────
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=
OPENAI_EMBEDDING_MODEL=
BEDROCK_EMBEDDING_MODEL=

# ── Weights & Biases (experiment tracking) ───────
# Benchmark runs log to W&B automatically; authenticate with
# `wandb login` or WANDB_API_KEY. Set WANDB_MODE=offline or
# disabled to run without an account.
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_MODE=online

# ── API Security ──────────────────────────────────
APP_API_KEY=
ALLOWED_ORIGINS=*

# ── CLI client (ingest/ask/explore against a secured server)
ONTOGRAPHRAG_API_KEY=

# ── Runtime ───────────────────────────────────────
HOST=0.0.0.0
PORT=8004
DOCKER_ENV=false

# ── Retrieval chunking (optional overrides) ───────
# RETRIEVAL_CHUNK_SIZE=256
# RETRIEVAL_CHUNK_OVERLAP=64

# Advanced KG-build and retrieval feature flags (KG_ENABLE_*,
# ONTOGRAPHRAG_*) are documented in README.md → Configuration.
